      "type": "row"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "airflow-postgres"
      },
      "description": "Airflow login records from the ab_user table. Shows each user's login count and most recent login timestamp. Requires the airflow-postgres datasource (provisioned in ticket 004).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": null,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "airflow-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT username, last_login, login_count FROM ab_user ORDER BY last_login DESC",
          "refId": "A"
        }
      ],
      "title": "Airflow Last Login",
      "type": "table"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Grafana audit log events from Loki. Shows user login and dashboard access events captured via GF_AUDIT_ENABLED=true (ticket 001). Newest entries at top.",
