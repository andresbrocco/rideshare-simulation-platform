...@_shared

direction: down

LOCAL: "Local Development — Docker Compose" {
  class: compute
  direction: right

  LS2: "LocalStack\nSecrets Manager\nemulation" { class: compute }
  SEED: "seed-secrets.py\nupserts 7 secret groups\nunder rideshare/*\ndefault: admin/admin" { class: compute }
  FETCH: "fetch-secrets.py\nreads groups, applies\nkey transformations:\nAirflow __, GF_ prefixes,\nbcrypt hash for Trino" { class: compute }
  VOL: "secrets-volume\n/secrets/core.env\n/secrets/data-pipeline.env\n/secrets/monitoring.env" { class: data; shape: cylinder }
  ENT: "Container entrypoint\nset -a\n. /secrets/core.env\nset +a\nexec app" { class: compute }

  LS2 -> SEED
  SEED -> FETCH
  FETCH -> VOL
  VOL -> ENT
}

PROD: "Production — EKS" {
  class: data
  direction: right

  SM: "AWS Secrets Manager\nrideshare/api-key\nrideshare/core\nrideshare/data-pipeline\nrideshare/monitoring\n(real random passwords)" { class: data }
  SS: "SecretStore CRD\npoints ESO at\nAWS Secrets Manager\n(node role credentials)" { class: config }
  ES: "ExternalSecret CRDs\napi-keys-sync → 1 key\napp-credentials-sync → 14 keys" { class: config }
  KS: "Kubernetes Secrets\napi-keys\napp-credentials" { class: neutral }
  POD: "Pod spec\nenv:\n  - name: REDIS_PASSWORD\n    valueFrom:\n      secretKeyRef:\n        name: app-credentials\n        key: REDIS_PASSWORD" { class: compute }

  SM -> SS
  SS -> ES
  ES -> KS
  KS -> POD
}
