...@_shared

direction: down

TF: "Terraform Apply — infrastructure/terraform/platform/" {
  class: compute
  T1: "1. EKS Cluster\ncontrol plane created\nAPI server available"
  T2: "2. vpc-cni + kube-proxy addons\nMUST exist before nodes join\nprovides pod networking + Service routing"
  T3: "3. Managed Node Group\n1x t3.xlarge, AL2023, 50GB gp3\nnodes join cluster, reach Ready state"
  T4: "4. eks-pod-identity-agent addon\nDaemonSet — needs nodes to schedule onto\nenables workload IAM credentials"
  T5: "5. ALB Controller (Helm)\ncreates mutating webhook\nmanages AWS load balancers from Ingress resources"
  T5B: "5b. ESO + kube-state-metrics (Helm)\nparallel with ALB controller\nexternal secrets sync + K8s metrics"
  T6: "6. coredns + ebs-csi addons\ninstalled AFTER ALB webhook ready\navoids webhook race condition"
  T7: "7. RDS PostgreSQL\nparallel with EKS setup\ncredentials written to Secrets Manager"

  T1 -> T2 -> T3 -> T4 -> T5
  T4 -> T5B
  T5 -> T6
  T1 -> T7
}

WF: "Deploy Workflow — post-Terraform" {
  class: config
  W1: "8. Create RDS databases\nkubectl run postgres:16 pod\nCREATE DATABASE airflow, metastore\nCREATE ROLE with grants"
  W2: "9. Install ArgoCD\nkubectl apply install.yaml (v3.2.3)\npatch argocd-cm for kustomize"
  W3: "10. Apply ArgoCD Application\nwatches deploy branch\nkustomize build overlay"

  W1 -> W2 -> W3
}

CONVERGE: "Phased Workload Convergence" {
  class: data
  P1: "Phase 1 — Infrastructure\nkafka, redis, prometheus,\nloki, tempo"
  P2: "Phase 2 — Schema\nschema-registry"
  P3: "Phase 3 — Application\nsimulation, stream-processor,\nbronze-ingestion, trino, osrm"
  P4: "Phase 4 — Data Pipeline\nairflow-webserver,\nairflow-scheduler"
  P5: "Phase 5 — UI & Observability\ngrafana, control-panel,\nperformance-controller"

  P1 -> P2 -> P3 -> P4 -> P5
}

POST: "Post-convergence\nprovision visitor accounts\nstart simulation\ncreate Route 53 wildcard DNS"

TF.T6 -> WF.W1
TF.T7 -> WF.W1
WF.W3 -> CONVERGE.P1
CONVERGE.P5 -> POST
