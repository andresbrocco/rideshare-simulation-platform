...@_shared

direction: down

RT: "Real-Time Pipeline" {
  class: compute

  SIM: "simulation:8000" {
    class: compute
  }
  KAFKA: "kafka-0.kafka:29092\nheadless StatefulSet" {
    class: compute
  }
  SR: "schema-registry:8081" {
    class: compute
  }
  SP: "stream-processor:8080" {
    class: compute
  }
  REDIS: "redis:6379" {
    class: compute
  }
  OSRM: "osrm:5000" {
    class: compute
  }
}

BATCH: "Batch Pipeline" {
  class: data

  BI: "bronze-ingestion" {
    class: data
  }
  AF: "airflow:8082\nscheduler + webserver" {
    class: data
  }
  TRINO: "trino:8080" {
    class: data
  }
  HIVE: "hive-metastore:9083\nThrift protocol" {
    class: data
  }
}

STORE: "Storage" {
  class: config

  S3: "S3 / MinIO:9000" {
    class: config
  }
  PG_HIVE: "postgres-metastore:5432" {
    class: config
  }
  PG_AF: "airflow-postgres:5432" {
    class: config
  }
  RDS: "RDS PostgreSQL:5432\nexternal to cluster" {
    class: config
  }
}

MON: "Monitoring" {
  class: monitoring

  GRAF: "grafana:3001" {
    class: monitoring
  }
  PROM: "prometheus:9090" {
    class: monitoring
  }
  LOKI: "loki:3100" {
    class: monitoring
  }
  TEMPO: "tempo:4317" {
    class: monitoring
  }
  OTEL: "otel-collector:4317" {
    class: monitoring
  }
}

# Real-time event flow
RT.SIM -> RT.KAFKA: "publish events"
RT.SIM -> RT.OSRM: "route geometry"
RT.SIM -> STORE.RDS: "checkpoint state"
RT.SP -> RT.KAFKA: "consume events"
RT.SP -> RT.SR: "validate schemas"
RT.SP -> RT.REDIS: "fan-out state"

# Batch data flow
BATCH.BI -> RT.KAFKA: "consume events"
BATCH.BI -> STORE.S3: "write bronze layer"
BATCH.AF -> BATCH.TRINO: "orchestrate DBT"
BATCH.TRINO -> BATCH.HIVE: "catalog queries"
BATCH.TRINO -> STORE.S3: "read/write Delta"
BATCH.HIVE -> STORE.PG_HIVE: "metadata"
BATCH.AF -> STORE.PG_AF: "DAG state"

# Monitoring flow
MON.PROM -> RT.SIM: "scrape /metrics" {
  style.stroke-dash: 3
}
MON.PROM -> RT.SP: "scrape /metrics" {
  style.stroke-dash: 3
}
MON.OTEL -> MON.PROM: "forward metrics" {
  style.stroke-dash: 3
}
MON.OTEL -> MON.LOKI: "forward logs" {
  style.stroke-dash: 3
}
MON.OTEL -> MON.TEMPO: "forward traces" {
  style.stroke-dash: 3
}
MON.GRAF -> MON.PROM: "query metrics"
MON.GRAF -> MON.LOKI: "query logs"
MON.GRAF -> MON.TEMPO: "query traces"
MON.GRAF -> BATCH.TRINO: "query analytics"
