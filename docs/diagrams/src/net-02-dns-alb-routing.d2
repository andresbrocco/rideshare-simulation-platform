...@_shared

direction: right

B: "Browser"

DNS: "Route 53" {
  class: data

  APEX: "A record\nridesharing.portfolio\n.andresbrocco.com" {
    class: data
  }
  WILD: "A records\n*.ridesharing.portfolio\n.andresbrocco.com" {
    class: data
  }
}

CDN: "CloudFront CDN" {
  class: config

  CF: "HTTPS only\nTLSv1.2\nOrigin Access Control" {
    class: config
  }
}

S3: "S3 Bucket\nReact SPA static files" {
  class: data
}

LB: "Shared ALB | IngressGroup: rideshare" {
  class: compute

  ALB: "HTTPS :443\nACM wildcard certificate\ntarget-type: ip" {
    class: compute
  }
}

PODS: "EKS Pods — routed by hostname" {
  SIM: "simulation:8000"
  GRAF: "grafana:3001"
  AIR: "airflow:8082"
  TRI: "trino:8080"
  PROM: "prometheus:9090"
  CP: "control-panel:80"
}

LAM: "Lambda Function URLs" {
  class: external

  AUTH: "auth-deploy\nvisitor auth + platform lifecycle" {
    class: external
  }
  CHAT: "ai-chat\nAI assistant" {
    class: external
  }
}

B -> DNS
DNS.APEX -> CDN.CF: "alias"
CDN.CF -> S3: "OAC sigv4"
DNS.WILD -> LB.ALB: "alias"
LB.ALB -> PODS.SIM: "api.*"
LB.ALB -> PODS.GRAF: "grafana.*"
LB.ALB -> PODS.AIR: "airflow.*"
LB.ALB -> PODS.TRI: "trino.*"
LB.ALB -> PODS.PROM: "prometheus.*"
LB.ALB -> PODS.CP: "control-panel.*"
B -> LAM: "direct HTTPS\nno DNS alias"
