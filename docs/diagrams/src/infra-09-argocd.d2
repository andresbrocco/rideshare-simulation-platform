...@_shared

direction: right

WF: "deploy-platform.yml" {
  class: compute
  CH: "Checkout main"
  RES: "Resolve placeholders\nsed: account-id, image-tag,\nrds-endpoint, acm-cert-arn,\nalb-sg-id, dbt-runner"
  PKG: "Package projects\ndbt-project.tar.gz\nge-project.tar.gz"
  FP: "git push --force\norigin deploy\ncommit: deploy: resolve\nproduction values [skip ci]"

  CH -> RES -> PKG -> FP
}

ARGO: "ArgoCD — in-cluster controller" {
  class: config
  POLL: "Poll deploy branch\n~3 min interval"
  KBUILD: "Kustomize build\nbase + component + overlay\n→ resolved manifests"
  DIFF: "Compute diff\nGit desired state\nvs cluster live state"
  SYNC: "kubectl apply\nnamespace: rideshare-prod\nCreateNamespace=true"
  RETRY: "Retry on failure\n5 attempts, exponential backoff\n5s → 10s → 20s → 40s → 80s\nmax 3 min"
}

CLUSTER: "EKS Cluster — rideshare-prod" {
  class: data
  LIVE: "Live Resources\nDeployments, Services,\nConfigMaps, Secrets..."
  HEAL: "Self-Heal\nmanual kubectl edit detected\n→ reverted to Git state"
  PRUNE: "Prune\nresource deleted from Git\n→ deleted from cluster"
  IGNORE: "ignoreDifferences\nDeployment/StatefulSet\nspec.replicas excluded\n(allows manual scaling)"
}

WF.FP -> ARGO.POLL: "branch updated"
ARGO.POLL -> ARGO.KBUILD -> ARGO.DIFF
ARGO.DIFF -> ARGO.SYNC: "changes found"
ARGO.SYNC -> CLUSTER.LIVE
ARGO.SYNC -> ARGO.RETRY: "failure"
ARGO.RETRY -> ARGO.SYNC
CLUSTER.LIVE -> CLUSTER.HEAL: "drift detected"
CLUSTER.HEAL -> ARGO.DIFF
ARGO.DIFF -> CLUSTER.PRUNE: "resource missing"
CLUSTER.IGNORE -> ARGO.DIFF: "skipped in\ndiff check" {
  style.stroke-dash: 3
}
