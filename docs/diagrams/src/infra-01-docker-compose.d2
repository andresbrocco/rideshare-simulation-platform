...@_shared

direction: down

LS: "localstack\nAWS emulation on :4566" { class: compute }
SI: "secrets-init\none-shot: seed-secrets.py → fetch-secrets.py\nwrites /secrets/core.env, data-pipeline.env, monitoring.env" { class: ephemeral }
LI: "lambda-init\none-shot: deploys auth + chat Lambdas to LocalStack" { class: ephemeral }

LS -> SI: "healthy"
SI -> LI: "completed"

CORE: "Core Profile" {
  class: compute

  K: "kafka\nKRaft, SASL/PLAIN" { class: compute }
  KI: "kafka-init\none-shot: creates 9 topics" { class: ephemeral }
  SR: "schema-registry\nBASIC auth" { class: compute }
  R: "redis\nrequirepass" { class: compute }
  OSRM: "osrm\nSao Paulo routing" { class: compute }
  SP: "stream-processor" { class: compute }
  SIM: "simulation\nthe main engine" { class: compute }
  CP: "control-panel\nReact + deck.gl" { class: compute }

  K -> KI: "healthy"
  KI -> SR
  KI -> SP
  R -> SP
  KI -> SIM
  SR -> SIM
  R -> SIM
  OSRM -> SIM
  SP -> SIM: "healthy"
  SIM -> CP: "healthy"
}

DATA: "Data-Pipeline Profile" {
  class: data

  M: "minio\nS3-compatible" { class: data }
  MI: "minio-init\none-shot: creates 7 buckets" { class: ephemeral }
  BI: "bronze-ingestion" { class: data }
  PA: "postgres-airflow" { class: data }
  PM: "postgres-metastore" { class: data }
  HM: "hive-metastore\nThrift :9083" { class: data }
  TR: "trino\nSQL engine" { class: data }
  AW: "airflow-webserver\nruns DB migrations" { class: data }
  AS: "airflow-scheduler" { class: data }
  DT: "delta-table-init\none-shot: registers Delta tables" { class: ephemeral }

  M -> MI: "healthy"
  MI -> BI
  PM -> HM: "healthy"
  M -> HM: "healthy"
  HM -> TR: "healthy"
  PA -> AW: "healthy"
  AW -> AS: "healthy"
  TR -> DT: "healthy"
  MI -> DT
}

MON: "Monitoring Profile" {
  class: monitoring

  PR: "prometheus" { class: monitoring }
  LO: "loki" { class: monitoring }
  TE: "tempo" { class: monitoring }
  OT: "otel-collector" { class: monitoring }
  GR: "grafana" { class: monitoring }
  CA: "cadvisor" { class: monitoring }
  KE: "kafka-exporter" { class: monitoring }
  RE: "redis-exporter" { class: monitoring }

  PR -> OT
  LO -> OT
  TE -> OT
  PR -> GR
  LO -> GR
  TE -> GR
}

PERF: "Performance Profile" {
  class: config

  PC: "perf-controller\nPID auto-scaler" { class: config }
}

DATA.KI -> DATA.BI
CORE.SIM -> PERF.PC
MON.PR -> PERF.PC
MON.OT -> PERF.PC

MON.MI -> MON.LO
MON.MI -> MON.TE

SI -> CORE.K: "all services wait\nfor this to complete" { style.stroke-dash: 3 }
SI -> CORE.R: "" { style.stroke-dash: 3 }
SI -> DATA.M: "" { style.stroke-dash: 3 }
SI -> DATA.PA: "" { style.stroke-dash: 3 }
SI -> DATA.PM: "" { style.stroke-dash: 3 }
SI -> MON.PR: "" { style.stroke-dash: 3 }
SI -> CORE.OSRM: "" { style.stroke-dash: 3 }
