...@_shared

direction: right

GH: "GitHub Actions — CI/CD Authentication" {
  class: compute
  RUNNER: "GitHub Actions Runner\nruns workflow job"
  OIDC: "GitHub OIDC Token\nsigned JWT proving:\nrepo, branch, workflow"
  STS_CI: "AWS STS\nAssumeRoleWith\nWebIdentity"
  ROLE_CI: "rideshare-github-actions\nIAM Role\ntrust: token.actions.\ngithubusercontent.com\ncondition: main branch only"
  PERMS_CI: "Permissions\nECR push, EKS deploy,\nTerraform state, S3, RDS,\nSecrets Manager, Route 53,\nCloudFront, Lambda..."

  RUNNER -> OIDC: "1. request token"
  OIDC -> STS_CI: "2. present to AWS"
  STS_CI -> ROLE_CI: "3. validate + assume"
  ROLE_CI -> PERMS_CI: "4. temporary creds"
}

K8S: "EKS — Workload Authentication" {
  class: data
  POD: "Pod\nServiceAccount: simulation\nnamespace: rideshare-prod"
  PIA: "Pod Identity Agent\nDaemonSet on every node\nintercepts credential requests"
  STS_POD: "AWS STS\nAssumeRole"
  ASSOC: "Pod Identity Association\nTerraform resource binding:\n(cluster, namespace, SA) → role"
  ROLE_POD: "rideshare-simulation\nIAM Role\ntrust: pods.eks.amazonaws.com\nactions: AssumeRole, TagSession"
  PERMS_POD: "Scoped Permissions\ne.g. simulation:\nS3 checkpoints R/W only\n\ne.g. loki:\nS3 loki bucket R/W only"

  POD -> PIA: "1. AWS SDK call"
  PIA -> ASSOC: "2. lookup association"
  ASSOC -> STS_POD: "3. resolve role"
  STS_POD -> ROLE_POD: "4. assume role"
  ROLE_POD -> PERMS_POD: "5. temporary creds"
}
