...@_shared

direction: down

BOOT: "bootstrap/ — Run once, local state" {
  class: bootstrap

  B_S3: "aws_s3_bucket\nrideshare-tf-state-*\nversioning enabled,\nprevent_destroy" { class: bootstrap }
}

FOUND: "foundation/ — Long-lived, ~8 USD/month at rest" {
  class: data

  F_VPC: "VPC\n10.0.0.0/16, 2 public subnets,\nIGW, 3 security groups" { class: data }
  F_IAM: "IAM Roles\nCI OIDC role (GitHub Actions),\nEKS cluster/node roles,\n9 Pod Identity workload roles,\nGlue job role" { class: data }
  F_S3: "S3 Buckets (11)\nbronze, silver, gold, checkpoints,\nfrontend, logs, loki, tempo,\nbuild-assets, ai-chat, tf-state" { class: data }
  F_ECR: "ECR Repos (8)\none per service, scan-on-push,\nkeep last 3 images" { class: data }
  F_SEC: "Secrets Manager (10)\nrideshare/*\nrandom passwords via\nhashicorp/random" { class: data }
  F_DNS: "Route 53 + ACM\nhosted zone + wildcard cert\nACM forced to us-east-1" { class: data }
  F_CF: "CloudFront\nSPA distribution,\nOrigin Access Control → S3" { class: data }
  F_GLUE: "Glue Catalog\nbronze, silver, gold DBs" { class: data }
  F_LAM: "Lambda Functions (3)\nauth-deploy, ai-chat, rds-reset" { class: data }
  F_DDB: "DynamoDB + KMS\nvisitor tables, encrypted" { class: data }
}

PLAT: "platform/ — Ephemeral, ~0.31 USD/hour" {
  class: config

  P_EKS: "EKS Cluster\nv1.35, API auth mode,\npublic endpoint only" { class: config }
  P_NG: "Node Group\n1x t3.xlarge, AL2023,\n50GB gp3, IMDSv2" { class: config }
  P_ADD: "EKS Add-ons (5)\nvpc-cni, kube-proxy, coredns,\nebs-csi, pod-identity-agent" { class: config }
  P_RDS: "RDS PostgreSQL\ndb.t4g.micro, v16.6,\nencrypted, 7-day backups" { class: config }
  P_HELM: "Helm Releases (3)\nALB Controller, ESO,\nkube-state-metrics" { class: config }
  P_PI: "Pod Identity Associations (9)\nsimulation, bronze-ingestion,\nairflow, trino, hive-metastore,\nloki, tempo, ESO, ALB controller" { class: config }
}

BOOT -> FOUND: "creates state bucket\nused by both layers below"
FOUND -> PLAT: "terraform_remote_state\nvpc_id, subnet_ids, sg_ids,\nrole_arns, secret_ids"
