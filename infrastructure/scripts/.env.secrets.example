# LLM provider API keys for local development.
# Copy this file to .env.secrets and fill in your real keys.
# Loaded automatically by seed-secrets.py and lambda-init on docker compose up.
#
# Only providers with non-empty keys will appear in the chat dropdown.
# Both OVERRIDE_ANTHROPIC and OVERRIDE_anthropic work (case-insensitive).
OVERRIDE_ANTHROPIC=
OVERRIDE_OPENAI=
OVERRIDE_GOOGLE=
OVERRIDE_DEEPSEEK=

# Default LLM provider for the chat widget (used by deploy-lambda.py).
# Set to "anthropic", "openai", "google", or "deepseek".
# Leave as "mock" if you don't want real LLM calls.
LLM_PROVIDER=google
